  },
  "componentSrcMap": {
    "CartButton": "components/header/CartButton.tsx",
    "CartFeedback": "components/cart/CartFeedback.tsx",
    "CartItem": "components/cart/CartItem.tsx",
    "CartSidebar": "components/cart/CartSidebar.tsx",
    "Filters": "components/catalog/Filters.tsx",
    "Footer": "components/footer/Footer.tsx",
    "Header": "components/header/Header.tsx",
    "Hero": "components/Hero.tsx",
    "Nav": "components/header/Nav.tsx",
    "Pagination": "components/catalog/Pagination.tsx",
    "PreviewProvider": null,
    "ProductCard": "components/catalog/ProductCard.tsx",
    "ProductCatalog": "components/catalog/ProductCatalog.tsx",
    "ProductGrid": "components/catalog/ProductGrid.tsx"
  },
  "overrides": {
    "CartSidebar": { "cardMode": "single", "viewport": "420x620" },
    "Header": { "cardMode": "single", "viewport": "1024x120" }
